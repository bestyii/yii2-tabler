{
  "name": "bestyii/yii2-tabler",
  "description": "Tabler UI framework for Yii2 based applications",
  "type": "yii2-extension",
  "keywords": [
    "yii2",
    "extension",
    "tabler",
    "bestyii"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "bestyii",
      "email": "hello@bestyii.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "yiisoft/yii2": "~2.0.32",
    "npm-asset/tabler--core": "^1.4",
    "npm-asset/tabler--icons-webfont": "^3.0",
    "npm-asset/tabler--icons": "^3.0",
    "bower-asset/jquery-masonry": "^4.2",
    "npm-asset/driver.js": "^1.3",
    "npm-asset/sortablejs": "~1.15"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "yiisoft/yii2-coding-standards": "~2.0",
    "phpunit/phpunit": "^13.0",
    "symplify/easy-coding-standard": "^12.1"
  },
  "autoload": {
    "psr-4": {
      "bestyii\\tabler\\": "src"
    }
  },
  "scripts": {
    "cs": "ecs check",
    "cs-fix": "ecs check --fix",
    "static": "phpstan analyse src tests --memory-limit=512M --autoload-file=phpstan-bootstrap.php",
    "tests": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "repositories": {
    "asset": {
      "type": "composer",
      "url": "https://asset-packagist.cn"
    },
    "packagist-aliyun": {
      "type": "composer",
      "url": "https://mirrors.tencent.com/composer/"
    }
  }
}
