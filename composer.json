{
  "name": "bestyii/yii2-tabler",
  "description": "Tabler UI framework for Yii2 based applications",
  "type": "yii2-extension",
  "keywords": [
    "yii2",
    "extension",
    "tabler",
    "bestyii"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "bestyii",
      "email": "hello@bestyii.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "yiisoft/yii2": "~2.0.32",
    "npm-asset/tabler--core": "^1.4",
    "npm-asset/tabler--icons-webfont": "^3.0",
    "npm-asset/apexcharts": "^3.0",
    "bower-asset/autosize": "^6.0",
    "bower-asset/clipboard": "^2.0",
    "npm-asset/countup.js": "^2.0",
 "npm-asset/driver.js": "^1.0",
    "npm-asset/dropzone": "^5.0",
    "npm-asset/fslightbox": "^3.0",
    "npm-asset/fullcalendar": "^6.0",
    "npm-asset/hotwired--turbo": "~8.0.18",
    "npm-asset/hugerte": "^1.0",
    "npm-asset/imask": "^7.0",
    "npm-asset/jsvectormap": "^1.5",
    "bower-asset/list.js": "^2.3",
    "npm-asset/litepicker": "^2.0",
    "npm-asset/melloware--coloris": "~0.25.0",
    "npm-asset/nouislider": "^15.0",
    "bower-asset/plyr": "^3.7",
    "bower-asset/signature_pad": "^5.0",
    "npm-asset/sortablejs": "~1.15",
    "bower-asset/star-rating.js": "^4.3",
    "npm-asset/tom-select": "^2.4",
    "npm-asset/typed.js": "^2.0"
  },
  "require-dev": {
    "yiisoft/yii2-coding-standards": "~2.0",
    "phpunit/phpunit": "^9.6",
    "symplify/easy-coding-standard": "^12.1"
  },
  "autoload": {
    "psr-4": {
      "bestyii\\tabler\\": "src"
    }
  },
  "scripts": {
    "cs": "ecs check",
    "cs-fix": "ecs check --fix",
    "static": "phpstan analyse",
    "tests": "phpunit"
  }
}
