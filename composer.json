{
  "name": "bestyii/yii2-tabler",
  "description": "Tabler UI framework for Yii2 based applications",
  "type": "yii2-extension",
  "keywords": [
    "yii2",
    "extension",
    "tabler",
    "bestyii"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "bestyii",
      "email": "hello@bestyii.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "yiisoft/yii2": "~2.0.32",
    "npm-asset/tabler--core": "^1.4",
    "npm-asset/tabler--icons-webfont": "^3.0",
    "npm-asset/tabler--icons": "^3.0",
    "bower-asset/jquery-masonry": "^4.2",
    "npm-asset/driver.js": "^1.3",
    "npm-asset/sortablejs": "~1.15"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "yiisoft/yii2-coding-standards": "~2.0",
    "phpunit/phpunit": "^11.5",
    "symplify/easy-coding-standard": "^12.1"
  },
  "autoload": {
    "psr-4": {
      "bestyii\\tabler\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "bestyii\\tabler\\tests\\": "tests"
    }
  },
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.cn"
    }
  ],
  "scripts": {
    "cs": "@php vendor/bin/ecs check src tests --ansi",
    "cs-fix": "@php vendor/bin/ecs check src tests --fix --ansi",
    "static": "@php vendor/bin/phpstan analyse -c phpstan.neon.dist --memory-limit=512M",
    "tests": "@php vendor/bin/phpunit -c phpunit.xml.dist --colors=always --no-coverage",
    "coverage:prepare": "@php -r \"is_dir('runtime/coverage/html') || mkdir('runtime/coverage/html', 0777, true);\"",
    "coverage": [
      "@coverage:prepare",
      "@php vendor/bin/phpunit -c phpunit.xml.dist --colors=always"
    ]
  }
}
